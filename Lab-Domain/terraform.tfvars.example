# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

# Proxmox connection
proxmox_endpoint     = "https://192.168.1.10:8006"
proxmox_api_token    = "root@pam!terraform=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
proxmox_ssh_password = "your-proxmox-root-password"
proxmox_node         = "pve"

# Storage / networking
datastore      = "local-lvm"
network_bridge = "vmbr0"

# Template VM IDs (must exist in Proxmox before apply)
dc_template_id    = 9100
win10_template_id = 9010
vm_id_base        = 8000   # DC=8000, clients=8001, 8002, ...

# Credentials (must match your template unattend.xml)
admin_password     = "LabAdmin123!"
safe_mode_password = "DSRMpass123!"

# Active Directory
domain_name    = "corp.local"
domain_netbios = "CORP"

# Clients
client_count = 2

# Lab profile: badblood | vulnad | none
lab_profile = "badblood"
